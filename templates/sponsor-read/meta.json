{
  "id": "sponsor-read",
  "name": "Sponsor-Read",
  "duration": 20,
  "aspectRatio": "16:9",
  "description": "Werbepartner-Einblendung mit Logo, Pitch und Promo-Code",
  "scenes": [
    {"id": 1, "from": 0, "to": 3, "name": "Logo-Reveal", "description": "Sponsor-Logo + Name"},
    {"id": 2, "from": 3, "to": 15, "name": "Brand-Card", "description": "2-Zeilen-Pitch"},
    {"id": 3, "from": 15, "to": 20, "name": "Promo", "description": "Promo-Code + Link"}
  ],
  "variables": [
    {"key": "SPONSOR_NAME", "label": "Name des Sponsors", "required": true, "example": "Acme Corp", "maxLength": 30},
    {"key": "SPONSOR_LOGO", "label": "Pfad zum Sponsor-Logo", "required": false, "example": "/path/to/logo.png"},
    {"key": "PITCH_LINE_1", "label": "Pitch Zeile 1", "required": true, "example": "Schluss mit langweiligen Tools.", "maxLength": 50},
    {"key": "PITCH_LINE_2", "label": "Pitch Zeile 2", "required": true, "example": "Acme bringt deine Arbeit auf das nächste Level.", "maxLength": 60},
    {"key": "PROMO_CODE", "label": "Promo-Code", "required": false, "example": "VIBECODING20", "maxLength": 20},
    {"key": "LINK", "label": "Link / URL", "required": true, "example": "acme.com/vibe", "maxLength": 40}
  ]
}
